# ============================================================
# Weekly App Review Pulse — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Analysis LLM (Gemini) ---
LLM_API_KEY=your-gemini-api-key-here
LLM_MODEL=gemini-2.0-flash

# --- Finalisation LLM (Groq) ---
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# --- MCP Server Endpoints ---
MCP_DOCS_ENDPOINT=http://localhost:3001
MCP_GMAIL_ENDPOINT=http://localhost:3002

# --- Pipeline Settings ---
PULSE_RECIPIENT=your-email@example.com
REVIEW_WINDOW_WEEKS=10
